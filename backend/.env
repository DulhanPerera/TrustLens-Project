# =========================
# TrustLens Environment
# =========================

# -------------------------
# MongoDB
# -------------------------
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=trustlens_db

MONGO_USER_COLLECTION=users
MONGO_TX_COLLECTION=transactions
MONGO_REPORT_COLLECTION=reports
MONGO_ACTIVITY_COLLECTION=activity_logs
MONGO_SETTINGS_COLLECTION=settings

# -------------------------
# Google Authentication
# -------------------------
GOOGLE_CLIENT_ID=729857577095-k5p6nbu7s8dnj8kh8sd6pvfehuiji4fp.apps.googleusercontent.com

# -------------------------
# Model / API behavior
# -------------------------
ENABLE_SHAP=1
MODEL_OUTPUT_IS_FRAUD=1

COMBINED_THR=0.5
AE_THR=0.01
REVIEW_MARGIN=0.05

# -------------------------
# SHAP
# -------------------------
SHAP_BG_PATH=shap_background.npy
SHAP_BG_MAX=500

# -------------------------
# Model paths
# -------------------------
MLP_MODEL_PATH=mlp_model.keras
AE_MODEL_PATH=autoencoder.keras
SCALER_PATH=scaler.joblib
CALIBRATOR_PATH=isotonic_calibrator.joblib
THRESHOLDS_PATH=thresholds.json

# -------------------------
# Admin / System behaviour
# -------------------------
DEFAULT_USER_ROLE=user
DEFAULT_ANALYST_ROLE=analyst
DEFAULT_ADMIN_ROLE=admin

ADMIN_ALLOWED_ROLES=admin,analyst

# -------------------------
# System Settings defaults
# -------------------------
SITE_NAME=TrustLens
MAINTENANCE_MODE=0
NOTIFICATIONS_ENABLED=1